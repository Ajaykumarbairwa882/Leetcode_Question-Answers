class Robot {
public:
    int w, h;
    int x = 0, y = 0;
    int dir = 0; // 0=East, 1=North, 2=West, 3=South
    int perimeter;
    bool moved = false;

    vector<string> dirs = {"East", "North", "West", "South"};

    Robot(int width, int height) {
        w = width;
        h = height;
        perimeter = 2 * (w + h) - 4;
    }

    void step(int num) {
        moved = true;
        num %= perimeter;

        while (num--) {
            if (dir == 0) { // East
                if (x + 1 < w) x++;
                else dir = 1, y++;
            }
            else if (dir == 1) { // North
                if (y + 1 < h) y++;
                else dir = 2, x--;
            }
            else if (dir == 2) { // West
                if (x - 1 >= 0) x--;
                else dir = 3, y--;
            }
            else { // South
                if (y - 1 >= 0) y--;
                else dir = 0, x++;
            }
        }
    }

    vector<int> getPos() {
        return {x, y};
    }

    string getDir() {
        if (!moved) return "East";
        if (x == 0 && y == 0) return "South";
        return dirs[dir];
    }
};
