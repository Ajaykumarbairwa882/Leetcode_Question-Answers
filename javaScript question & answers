// 6. Longest Word

function findLongestWord(sentence) {
  let words = [];
  let word = "";
  for (let i = 0; i <= sentence.length; i++) {
    if (i === sentence.length || sentence[i] === " ") {
      words.push(word);
      word = "";
    } else {
      word += sentence[i];
    }
  }
  let longest = words[0];
  for (let i = 1; i < words.length; i++) {
    if (words[i].length > longest.length) longest = words[i];
  }
  return longest;
}
