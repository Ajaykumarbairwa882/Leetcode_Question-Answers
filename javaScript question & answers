  for (let i = 0; i < s.length; i++) {
    for (let j = i; j < s.length; j++) {
      let substr = s.slice(i,j+1);
      let reversed = "";
      for (let k = substr.length-1; k >=0; k--) reversed += substr[k];
      if (substr === reversed && substr.length > longest.length) {
        longest = substr;
      }
    }
  }
  return longest;
}
