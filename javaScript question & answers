// 44. Generate All Permutations of a String

function permute(str) {
  let result = [];
  function helper(prefix, remaining) {
    if (remaining.length === 0) result.push(prefix);
    for (let i = 0; i < remaining.length; i++) {
      helper(prefix + remaining[i], remaining.slice(0,i)+remaining.slice(i+1));
    }
  }
  helper("", str);
  return result;
}
console.log(permute("abc")); // ["abc","acb","bac","bca","cab","cba"]

// 45. Longest Substring Without Repeating Characters

function longestUniqueSubstring(str) {
  let longest = "";
  for (let i = 0; i < str.length; i++) {
    let seen = {};
    let temp = "";
    for (let j = i; j < str.length; j++) {
      if (seen[str[j]]) break;
      temp += str[j];
      seen[str[j]] = true;
    }
    if (temp.length > longest.length) longest = temp;
  }
  return longest;
}
console.log(longestUniqueSubstring("abcabcbb")); // "abc"

// 46. Smallest Substring with All Unique Characters

function smallestUniqueSubstring(str) {
  let uniqueChars = {};
  for (let i = 0; i < str.length; i++) uniqueChars[str[i]] = true;
  let totalUnique = Object.keys(uniqueChars).length;
  let minLen = str.length+1, minSub = "";
  for (let i = 0; i < str.length; i++) {
    let seen = {};
    let count = 0;
    for (let j = i; j < str.length; j++) {
      if (!seen[str[j]]) {
        seen[str[j]] = true;
        count++;
      }
      if (count === totalUnique && (j-i+1) < minLen) {
        minLen = j-i+1;
        minSub = str.slice(i,j+1);
        break;
      }
    }
  }
  return minSub;
}
console.log(smallestUniqueSubstring("aabcbcdbca")); // "dbca"

// 47. String Compression

function compressString(str) {
  let result = "";
  let count = 1;
  for (let i = 0; i < str.length; i++) {
    if (str[i] === str[i+1]) count++;
    else {
      result += str[i] + count;
      count = 1;
    }
  }
  return result;
}
console.log(compressString("aaabbc")); // "a3b2c1"

// 48. Convert Roman to Integer

function romanToInt(s) {
  let map = {I:1,V:5,X:10,L:50,C:100,D:500,M:1000};
  let total = 0;
  for (let i = 0; i < s.length; i++) {
    if (map[s[i]] < map[s[i+1]] || i === s.length-1) total += map[s[i]];
    else total -= map[s[i]];
  }
  return total;
}
console.log(romanToInt("XIV")); // 14\

// 49. Convert Integer to Roman

function intToRoman(num) {
  let val = [1000,900,500,400,100,90,50,40,10,9,5,4,1];
  let sym = ["M","CM","D","CD","C","XC","L","XL","X","IX","V","IV","I"];
  let result = "";
  for (let i = 0; i < val.length; i++) {
    while (num >= val[i]) {
      num -= val[i];
      result += sym[i];
    }
  }
  return result;
}
console.log(intToRoman(58)); // "LVIII"

// 50. Minimum Edit Distance

function minEditDistance(str1,str2) {
  let m = str1.length, n = str2.length;
  let dp = [];
  for (let i = 0; i <= m; i++) {
    dp[i] = [];
    for (let j = 0; j <= n; j++) {
      if (i === 0) dp[i][j] = j;
      else if (j === 0) dp[i][j] = i;
      else dp[i][j] = 0;
    }
  }
  for (let i = 1; i <= m; i++) {
    for (let j = 1; j <= n; j++) {
      if (str1[i-1] === str2[j-1]) dp[i][j] = dp[i-1][j-1];
      else dp[i][j] = 1 + Math.min(dp[i-1][j-1], dp[i-1][j], dp[i][j-1]);
    }
  }
  return dp[m][n];
}
console.log(minEditDistance("horse","ros")); // 3

