// 32. Longest Consecutive Sequence

function longestConsecutive(arr) {
  let set = {};
  for (let i = 0; i < arr.length; i++) set[arr[i]] = true;
  let longest = 0;
  for (let i = 0; i < arr.length; i++) {
    if (!set[arr[i]-1]) {
      let count = 1;
      let next = arr[i]+1;
      while (set[next]) {
        count++;
        next++;
      }
      if (count > longest) longest = count;
    }
  }
  return longest;
}
